<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.heritage.mapper.HeritageUserActionMapper">

    <resultMap type="HeritageUserAction" id="HeritageUserActionResult">
        <result property="actionId"    column="action_id"    />
        <result property="userId"      column="user_id"      />
        <result property="itemId"      column="item_id"      />
        <result property="actionType"  column="action_type"  />
        <result property="createTime"  column="create_time"  />
    </resultMap>

    <!-- 查询记录是否存在 -->
    <select id="selectCountByAction" parameterType="HeritageUserAction" resultType="Integer">
        select count(1) from heritage_user_action
        <where>
            <if test="userId != null"> and user_id = #{userId}</if>
            <if test="itemId != null"> and item_id = #{itemId}</if>
            <if test="actionType != null"> and action_type = #{actionType}</if>
        </where>
    </select>

    <!-- 插入记录 -->
    <insert id="insertAction" parameterType="HeritageUserAction" useGeneratedKeys="true" keyProperty="actionId">
        insert into heritage_user_action (
        <if test="userId != null">user_id,</if>
        <if test="itemId != null">item_id,</if>
        <if test="actionType != null">action_type,</if>
        create_time
        ) values (
        <if test="userId != null">#{userId},</if>
        <if test="itemId != null">#{itemId},</if>
        <if test="actionType != null">#{actionType},</if>
        sysdate()
        )
    </insert>

    <!-- 删除记录 -->
    <delete id="deleteAction" parameterType="HeritageUserAction">
        delete from heritage_user_action
        where user_id = #{userId}
          and item_id = #{itemId}
          and action_type = #{actionType}
    </delete>

    <!-- 专门用于进入详情页时检查状态 -->
    <select id="checkStatus" resultType="Integer">
        select count(1) from heritage_user_action
        where user_id = #{userId}
          and item_id = #{itemId}
          and action_type = #{actionType}
    </select>

</mapper>