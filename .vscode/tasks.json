{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Spring Boot (ruoyi-admin)",
      "type": "shell",
      "command": "mvn spring-boot:run -pl ruoyi-admin -am",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Maven install (skip tests)",
      "type": "shell",
      "command": "mvn clean install -DskipTests",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$javac"
    }
  ]
}
